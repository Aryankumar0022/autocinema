# ============================================================
# AutoCinema API Keys Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# 1. Google AI Studio (Free) -> https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Together AI (Free $25 credits) -> https://www.together.ai/
TOGETHER_API_KEY=your_together_api_key_here

# 3. Hugging Face (Free) -> https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# 4. Groq Cloud (Free) -> https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Replicate (Pay-as-you-go backup)
REPLICATE_API_KEY=your_replicate_api_key_here
