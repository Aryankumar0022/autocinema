# ============================================================
# AutoCinema API Keys Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# 1. Google AI Studio (Free) -> https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Hugging Face (Free) -> https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# 3. Groq Cloud (Free) -> https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── Image Generation ──────────────────────────────────────────
# Uses Pollinations.ai — 100% free, NO API key required!
# No configuration needed for image generation.
Pollinations_API_Key=
# # Optional: Together AI (backup, requires credits)
# TOGETHER_API_KEY=your_together_api_key_here

# # Optional: Replicate (Pay-as-you-go backup)
# REPLICATE_API_KEY=your_replicate_api_key_here
